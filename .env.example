# =============================================================================
# FormaNova Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================


# =============================================================================
# AZURE BLOB STORAGE (Required for image storage)
# =============================================================================
AZURE_ACCOUNT_NAME=jewelrytryon
AZURE_ACCOUNT_KEY=your-azure-account-key-here
AZURE_CONTAINER_NAME=jewelry-uploads


# =============================================================================
# BACKEND SERVICES - Main Infrastructure
# =============================================================================

# Temporal/DAG Workflow Gateway (Primary orchestration)
TEMPORAL_API_URL=

# Direct API (Multipart uploads, masking endpoints)
DIRECT_API_URL=

# Auth Service (Custom auth & Google OAuth)
AUTH_SERVICE_URL=

# =============================================================================
# GPU SERVERS (A100)
# =============================================================================

# Primary A100 Server (Generation/Refinement)
A100_JEWELRY_URL=

# Alternate A100 Server (Examples gallery)
A100_ALTERNATE_URL=

# =============================================================================
# MICROSERVICES - ML Inference
# =============================================================================

# Image Manipulator (Resize, zoom detection) - Azure VM
IMAGE_MANIPULATOR_URL=

# BiRefNet (Background removal) - Modal.com hosted
BIREFNET_URL=

# SAM3 (Segment Anything Model 3) - Modal.com hosted  
SAM3_URL=

# Flux Fill (Image inpainting) - Modal.com hosted
FLUX_FILL_URL=

# =============================================================================
# TEMPORAL BACKEND (Docker/Self-hosted only)
# =============================================================================
# These are only needed when running the temporal-backend locally

# Temporal Server
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# PostgreSQL Database for Temporal
DB_HOST=localhost
DB_PORT=5432
DB_NAME=formanova
DB_USER=postgres
DB_PASSWORD=your-postgres-password

# Or use a full connection URL instead
DATABASE_URL=

# API Server Port
API_PORT=8001

# =============================================================================
# EXTERNAL CONTENT
# =============================================================================

# YouTube Tutorial Video ID
YOUTUBE_TUTORIAL_ID=0iS8ypFCSU0

# Canonical public site URL for this deployment.
# Staging should set this to its own public origin, e.g. https://staging.formanova.ai.
VITE_PUBLIC_SITE_URL=https://formanova.ai

# Comma-separated hosts allowed to render without redirect.
# Supports exact hosts and suffix wildcards such as *.vercel.app. Do not use broad "*".
# Staging should include its own host here, e.g. staging.formanova.ai.
VITE_ALLOWED_HOSTS=formanova.ai,www.formanova.ai

# PostHog relay host
VITE_POSTHOG_API_HOST=https://relay.formanova.ai

# =============================================================================
# TEMPORARY FRONTEND FEATURE ALLOWLISTS
# =============================================================================
# Comma-separated email lists for UI-only temporary access gates.
# These are not security boundaries; durable access control belongs in backend/admin config.
VITE_WEIGHT_STL_ALLOWLIST_EMAILS=
VITE_CAD_UPLOAD_ALLOWLIST_EMAILS=
VITE_SHOW_ALL_VAULT_ALLOWLIST_EMAILS=
VITE_STUDIO_TYPE_SELECTION_ALLOWLIST_EMAILS=
VITE_PRODUCT_SHOT_GUIDE_ALLOWLIST_EMAILS=
VITE_TEST_MENU_ALLOWLIST_EMAILS=
